{
  "version": 2,
  "name": "cyber-divination",
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/zb",
      "dest": "/占卜页面-付费完整版.html"
    },
    {
      "src": "/free",
      "dest": "/占卜页面-免费体验版.html"
    },
    {
      "src": "/test",
      "dest": "/占卜页面-测试版.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
